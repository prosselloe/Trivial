at" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberSeguretat</field><statement name="DO"><block type="controls_openAnotherScreen" id="+RqY]-oRXFae+B=?SMGs"><value name="SCREEN"><block type="helpers_screen_names" id="Y+E{SS!_uXqYJL6U6ev$"><field name="SCREEN">Screen1</field></block></value></block></statement></block><block type="component_event" id="s;J`L.@#+oLHv7U!+#K]" x="-404" y="2106"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberDau" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberDau</field><statement name="DO"><block type="controls_openAnotherScreen" id="PptJiBw*tx]3Id{ZPXo-"><value name="SCREEN"><block type="helpers_screen_names" id="k02v@mg=)O5dH(mL2`UN"><field name="SCREEN">CiberDau</field></block></value></block></statement></block><block type="component_event" id="est9k^b/KOI!P:dEubMi" x="-916" y="2175"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberTauler" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberTauler</field><statement name="DO"><block type="controls_openAnotherScreen" id="$xe.$bIu0ac(tZG5oXNn"><value name="SCREEN"><block type="helpers_screen_names" id="h}~i@(SgWc/cUY2t:4=."><field name="SCREEN">CiberTauler</field></block></value></block></statement></block><block type="component_event" id="J@]j9{CK2%VWhG[il|+l" x="-403" y="2176"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberPunt" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberPunt</field><statement name="DO"><block type="controls_openAnotherScreen" id="aS3UI8HlcRI[f{qUkVP`"><value name="SCREEN"><block type="helpers_screen_names" id="L+,6z{kOVIK6wiTOec?E"><field name="SCREEN">CiberPunts</field></block></value></block></statement></block><block type="global_declaration" id="IZ`IKqj.Vn3p0VcI;jYe" x="-917" y="2247"><field name="NAME">Pregunta11</field><value name="VALUE"><block type="lists_create_with" id="+,.HumX1Ph96P/%0[G7f"><mutation xmlns="http://www.w3.org/1999/xhtml" items="6"></mutation><value name="ADD0"><block type="text" id="Ln49[_:X7BUax]2-,cpC"><field name="TEXT">11)&#9;Estàs tancant la compra d’un article a través d’una plataforma de compravenda. El venedor et demana fer una transferència a un banc estranger. És una transacció segura?</field></block></value><value name="ADD1"><block type="text" id="g]^!M8~hN8nQ(`e/i%-]"><field name="TEXT">a)&#9;Sí, les transferències són el mètode de pagament més segur.</field></block></value><value name="ADD2"><block type="text" id="It5IYpd8QW[RR]^U$#AH"><field name="TEXT">b)&#9;Sí, sempre que el venedor m'enviï proves d'estar en possessió de l'article per WhatsApp.</field></block></value><value name="ADD3"><block type="text" id="}{C4$NA9:m^)ZvM.N;Nb"><field name="TEXT">c)&#9;No, si hi hagués cap problema seria difícil recuperar els meus doblers.</field></block></value><value name="ADD4"><block type="text" id="/C7F:[m#*x0z_YEYO(m/"><field name="TEXT">c)&#9;No, si hi hagués cap problema seria difícil recuperar els meus doblers.</field></block></value><value name="ADD5"><block type="text" id="~:wnet.0B6mSbtHvEj[l"><field name="TEXT">Resposta: El principal problema de fer una transferència a un banc estranger és que, en cas de resultar ser víctima d'un frau i voler recuperar els nostres doblers, seria complicat.</field></block></value></block></value></block><yacodeblocks xmlns="http://www.w3.org/1999/xhtml" ya-version="232" language-version="37"></yacodeblocks></xml>