Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberDau</field><statement name="DO"><block type="controls_openAnotherScreen" id="PptJiBw*tx]3Id{ZPXo-"><value name="SCREEN"><block type="helpers_screen_names" id="k02v@mg=)O5dH(mL2`UN"><field name="SCREEN">CiberDau</field></block></value></block></statement></block><block type="component_event" id="est9k^b/KOI!P:dEubMi" x="-904" y="2183"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberTauler" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberTauler</field><statement name="DO"><block type="controls_openAnotherScreen" id="$xe.$bIu0ac(tZG5oXNn"><value name="SCREEN"><block type="helpers_screen_names" id="h}~i@(SgWc/cUY2t:4=."><field name="SCREEN">CiberTauler</field></block></value></block></statement></block><block type="component_event" id="J@]j9{CK2%VWhG[il|+l" x="-394" y="2187"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberPunt" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberPunt</field><statement name="DO"><block type="controls_openAnotherScreen" id="aS3UI8HlcRI[f{qUkVP`"><value name="SCREEN"><block type="helpers_screen_names" id="L+,6z{kOVIK6wiTOec?E"><field name="SCREEN">CiberPunts</field></block></value></block></statement></block><block type="global_declaration" id="IZ`IKqj.Vn3p0VcI;jYe" x="-907" y="2257"><field name="NAME">Pregunta01</field><value name="VALUE"><block type="lists_create_with" id="+,.HumX1Ph96P/%0[G7f"><mutation xmlns="http://www.w3.org/1999/xhtml" items="6"></mutation><value name="ADD0"><block type="text" id="Ln49[_:X7BUax]2-,cpC"><field name="TEXT">1)&#9;Què es considera una contrasenya robusta?</field></block></value><value name="ADD1"><block type="text" id="g]^!M8~hN8nQ(`e/i%-]"><field name="TEXT">a)&#9;Aquella amb més de 5 caràcters.</field></block></value><value name="ADD2"><block type="text" id="It5IYpd8QW[RR]^U$#AH"><field name="TEXT">b)&#9;Aquella que té números, majúscules, minúscules i caràcters especials.</field></block></value><value name="ADD3"><block type="text" id="}{C4$NA9:m^)ZvM.N;Nb"><field name="TEXT">c)&#9;Qualsevol, el més important és poder recordar-la.</field></block></value><value name="ADD4"><block type="text" id="/C7F:[m#*x0z_YEYO(m/"><field name="TEXT">b)&#9;Aquella que té números, majúscules, minúscules i caràcters especials.</field></block></value><value name="ADD5"><block type="text" id="~:wnet.0B6mSbtHvEj[l"><field name="TEXT">Resposta: Una contrasenya robusta serà aquella que contengui una combinació de lletres, números, majúscules, minúscules i caràcters especials.</field></block></value></block></value></block><yacodeblocks xmlns="http://www.w3.org/1999/xhtml" ya-version="232" language-version="37"></yacodeblocks></xml>