d name="COMPONENT_SELECTOR">BtnCiberSeguretat</field><statement name="DO"><block type="controls_openAnotherScreen" id="+RqY]-oRXFae+B=?SMGs"><value name="SCREEN"><block type="helpers_screen_names" id="Y+E{SS!_uXqYJL6U6ev$"><field name="SCREEN">Screen1</field></block></value></block></statement></block><block type="component_event" id="s;J`L.@#+oLHv7U!+#K]" x="-384" y="2277"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberDau" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberDau</field><statement name="DO"><block type="controls_openAnotherScreen" id="PptJiBw*tx]3Id{ZPXo-"><value name="SCREEN"><block type="helpers_screen_names" id="k02v@mg=)O5dH(mL2`UN"><field name="SCREEN">CiberDau</field></block></value></block></statement></block><block type="component_event" id="est9k^b/KOI!P:dEubMi" x="-905" y="2344"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberTauler" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberTauler</field><statement name="DO"><block type="controls_openAnotherScreen" id="$xe.$bIu0ac(tZG5oXNn"><value name="SCREEN"><block type="helpers_screen_names" id="h}~i@(SgWc/cUY2t:4=."><field name="SCREEN">CiberTauler</field></block></value></block></statement></block><block type="component_event" id="J@]j9{CK2%VWhG[il|+l" x="-384" y="2348"><mutation xmlns="http://www.w3.org/1999/xhtml" component_type="Button" is_generic="false" instance_name="BtnCiberPunt" event_name="Click"></mutation><field name="COMPONENT_SELECTOR">BtnCiberPunt</field><statement name="DO"><block type="controls_openAnotherScreen" id="aS3UI8HlcRI[f{qUkVP`"><value name="SCREEN"><block type="helpers_screen_names" id="L+,6z{kOVIK6wiTOec?E"><field name="SCREEN">CiberPunts</field></block></value></block></statement></block><block type="global_declaration" id="IZ`IKqj.Vn3p0VcI;jYe" x="-905" y="2415"><field name="NAME">Pregunta41</field><value name="VALUE"><block type="lists_create_with" id="+,.HumX1Ph96P/%0[G7f"><mutation xmlns="http://www.w3.org/1999/xhtml" items="6"></mutation><value name="ADD0"><block type="text" id="Ln49[_:X7BUax]2-,cpC"><field name="TEXT">41)&#9;Els connectors, addons o complements utilitzats pels navegadors són sempre segurs?</field></block></value><value name="ADD1"><block type="text" id="g]^!M8~hN8nQ(`e/i%-]"><field name="TEXT">a)&#9;Només quan els descàrrec de llocs no oficials.</field></block></value><value name="ADD2"><block type="text" id="It5IYpd8QW[RR]^U$#AH"><field name="TEXT">b)&#9;Sí. Precisament m'ajuden a millorar la seguretat.</field></block></value><value name="ADD3"><block type="text" id="}{C4$NA9:m^)ZvM.N;Nb"><field name="TEXT">c)&#9;No. Fins i tot un de fiable pot presentar vulnerabilitats.</field></block></value><value name="ADD4"><block type="text" id="/C7F:[m#*x0z_YEYO(m/"><field name="TEXT">c)&#9;No. Fins i tot un de fiable pot presentar vulnerabilitats.</field></block></value><value name="ADD5"><block type="text" id="~:wnet.0B6mSbtHvEj[l"><field name="TEXT">Resposta: Com les aplicacions, aquests complements poden ser maliciosos o presentar vulnerabilitats. El millor és descarregar-los de llocs oficials i revisar els comentaris i les valoracions d'altres usuaris.</field></block></value></block></value></block><yacodeblocks xmlns="http://www.w3.org/1999/xhtml" ya-version="232" language-version="37"></yacodeblocks></xml>